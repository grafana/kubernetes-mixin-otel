diff --git a/scripts/generate-fixtures.mjs b/scripts/generate-fixtures.mjs
new file mode 100644
index 0000000..1aa8e18
--- /dev/null
+++ b/scripts/generate-fixtures.mjs
@@ -0,0 +1,79 @@
+// Generates the language-agnostic conformance corpus in spec/fixtures/ by
+// running the real jest spec files (unmodified) with the public API wrapped
+// in recording proxies. Every `promql.*` call and every `Expression` usage
+// the suite makes becomes a fixture case: { fn, params, expected | error }.
+//
+// Other implementations of the tsqtsq API (currently jsonnet/) replay these
+// fixtures to prove behavioural equivalence with the TypeScript source of
+// truth. Regenerate with: pnpm run generate:fixtures
+import * as esbuild from 'esbuild';
+import { mkdirSync, readdirSync, writeFileSync, rmSync } from 'node:fs';
+import { dirname, join, resolve } from 'node:path';
+import { fileURLToPath, pathToFileURL } from 'node:url';
+
+const root = resolve(dirname(fileURLToPath(import.meta.url)), '..');
+
+// prettify is TypeScript-only (it wraps the lezer PromQL parser) and is
+// deliberately out of scope for the cross-language conformance corpus.
+const EXCLUDED_SPECS = new Set(['prettify.spec.ts']);
+
+const specs = [
+  ...readdirSync(join(root, 'src/test'))
+    .filter((f) => f.endsWith('.spec.ts') && !EXCLUDED_SPECS.has(f))
+    .sort()
+    .map((f) => ({ suite: f.replace('.spec.ts', ''), path: `./src/test/${f}` })),
+  { suite: 'expression', path: './src/expression.spec.ts' },
+];
+
+const entry = [
+  `import './scripts/lib/jest-shim';`,
+  `import { setSuite, recorded } from './scripts/lib/recorder-state';`,
+  `import { stats } from './scripts/lib/jest-shim';`,
+  ...specs.map(({ suite, path }) => `setSuite(${JSON.stringify(suite)});\nawait import(${JSON.stringify(path)});`),
+  `export { recorded, stats };`,
+].join('\n');
+
+// The spec files import the implementation under test; redirect those imports
+// to the recording wrappers. Everything else resolves normally.
+const redirectToRecorder = {
+  name: 'redirect-to-recorder',
+  setup(build) {
+    build.onResolve({ filter: /^\.\.?\/promql$/ }, (args) =>
+      args.importer.endsWith('.spec.ts') ? { path: join(root, 'scripts/lib/record-promql.ts') } : undefined
+    );
+    build.onResolve({ filter: /^\.\.?\/expression$/ }, (args) =>
+      args.importer.endsWith('.spec.ts') ? { path: join(root, 'scripts/lib/record-expression.ts') } : undefined
+    );
+  },
+};
+
+const outDir = join(root, 'node_modules/.cache/tsqtsq-fixtures');
+const outFile = join(outDir, 'record.mjs');
+mkdirSync(outDir, { recursive: true });
+
+await esbuild.build({
+  stdin: { contents: entry, resolveDir: root, loader: 'ts' },
+  bundle: true,
+  platform: 'node',
+  format: 'esm',
+  outfile: outFile,
+  plugins: [redirectToRecorder],
+  logLevel: 'silent',
+});
+
+const { recorded, stats } = await import(pathToFileURL(outFile).href);
+rmSync(outDir, { recursive: true, force: true });
+
+const fixtures = {
+  '//': 'GENERATED by scripts/generate-fixtures.mjs from the jest suite -- DO NOT EDIT.',
+  cases: recorded,
+};
+
+mkdirSync(join(root, 'spec/fixtures'), { recursive: true });
+writeFileSync(join(root, 'spec/fixtures/conformance.json'), JSON.stringify(fixtures, null, 2) + '\n');
+
+const errors = recorded.filter((c) => c.error !== undefined).length;
+console.log(
+  `ran ${stats.assertions} assertions, recorded ${recorded.length} conformance cases ` +
+    `(${recorded.length - errors} expressions, ${errors} errors) -> spec/fixtures/conformance.json`
+);
diff --git a/scripts/lib/jest-shim.ts b/scripts/lib/jest-shim.ts
new file mode 100644
index 0000000..019c176
--- /dev/null
+++ b/scripts/lib/jest-shim.ts
@@ -0,0 +1,44 @@
+// Minimal jest shim so the real spec files can run unmodified outside jest
+// while the recorder captures their public API calls. Only the matchers the
+// suite actually uses are implemented; anything else fails loudly.
+
+export const stats = { assertions: 0 };
+
+type SpecFn = (arg?: unknown) => void;
+
+const describe = (_name: string, fn: () => void) => fn();
+
+const it = (_name: string, fn: SpecFn) => fn();
+it.each =
+  (cases: unknown[]) =>
+  (_title: string, fn: SpecFn) =>
+    cases.forEach((c) => fn(c));
+
+const expect = (actual: unknown) => ({
+  toStrictEqual: (expected: unknown) => {
+    stats.assertions++;
+    if (actual !== expected) {
+      throw new Error(`expected ${JSON.stringify(expected)}, got ${JSON.stringify(actual)}`);
+    }
+  },
+  toEqual(expected: unknown) {
+    this.toStrictEqual(expected);
+  },
+  toThrow: (message?: string) => {
+    stats.assertions++;
+    let thrown: Error | undefined;
+    try {
+      (actual as () => unknown)();
+    } catch (e) {
+      thrown = e as Error;
+    }
+    if (thrown === undefined) {
+      throw new Error('expected function to throw');
+    }
+    if (message !== undefined && !thrown.message.includes(message)) {
+      throw new Error(`expected error containing ${JSON.stringify(message)}, got ${JSON.stringify(thrown.message)}`);
+    }
+  },
+});
+
+Object.assign(globalThis, { describe, it, test: it, expect });
diff --git a/scripts/lib/record-expression.ts b/scripts/lib/record-expression.ts
new file mode 100644
index 0000000..2d600e7
--- /dev/null
+++ b/scripts/lib/record-expression.ts
@@ -0,0 +1,47 @@
+// Recording wrapper around the real Expression class. The fixture generator
+// aliases the spec files' `import { Expression } from './expression'` to this
+// module. Construction options and setSelector() calls are captured, and the
+// case is recorded when toString() is called (which is when the output that
+// the spec asserts on is produced).
+import { Expression as RealExpression } from '../../src/expression';
+import { LabelSelector, LabelsWithValues, MatchingOperator } from '../../src/types';
+import { record } from './recorder-state';
+
+type ExpressionOpts = {
+  metric: string;
+  values: LabelsWithValues;
+  defaultOperator: MatchingOperator;
+  defaultSelectors?: LabelSelector[];
+};
+
+export class Expression extends RealExpression {
+  private readonly opts: ExpressionOpts;
+  private readonly extraSelectors: LabelSelector[] = [];
+
+  constructor(opts: ExpressionOpts) {
+    super(opts);
+    this.opts = opts;
+  }
+
+  setSelector(selector: LabelSelector) {
+    // The base constructor applies defaultSelectors through setSelector before
+    // this subclass's fields initialize; those are already captured via opts.
+    if (this.extraSelectors !== undefined) {
+      this.extraSelectors.push(selector);
+    }
+    return super.setSelector(selector);
+  }
+
+  toString(): string {
+    const result = super.toString();
+    record({
+      fn: 'Expression',
+      params: {
+        ...this.opts,
+        ...(this.extraSelectors.length > 0 ? { setSelectors: this.extraSelectors } : {}),
+      },
+      expected: result,
+    });
+    return result;
+  }
+}
diff --git a/scripts/lib/record-promql.ts b/scripts/lib/record-promql.ts
new file mode 100644
index 0000000..5488442
--- /dev/null
+++ b/scripts/lib/record-promql.ts
@@ -0,0 +1,33 @@
+// Recording wrapper around the real `promql` object. The fixture generator
+// aliases the spec files' `import { promql } from '../promql'` to this module,
+// so every public API call made by the jest suite is captured as a fixture.
+import { promql as real } from '../../src/promql';
+import { record } from './recorder-state';
+
+export const promql: typeof real = new Proxy(real, {
+  get(target, prop: string) {
+    const orig = (target as Record<string, unknown>)[prop];
+    if (typeof orig !== 'function') {
+      return orig;
+    }
+    return (...args: unknown[]) => {
+      // Public API functions take a single params object. Internal helpers
+      // (x_over_time, binaryOp, by, without, byOrWithout) take positional
+      // arguments and are not part of the cross-language contract.
+      const isPublic =
+        args.length === 1 && typeof args[0] === 'object' && args[0] !== null && !Array.isArray(args[0]);
+      try {
+        const result = (orig as (...a: unknown[]) => unknown).apply(target, args);
+        if (isPublic && typeof result === 'string') {
+          record({ fn: prop, params: args[0], expected: result });
+        }
+        return result;
+      } catch (e) {
+        if (isPublic && e instanceof Error) {
+          record({ fn: prop, params: args[0], error: e.message });
+        }
+        throw e;
+      }
+    };
+  },
+});
diff --git a/scripts/lib/recorder-state.ts b/scripts/lib/recorder-state.ts
new file mode 100644
index 0000000..70d58fd
--- /dev/null
+++ b/scripts/lib/recorder-state.ts
@@ -0,0 +1,31 @@
+// Shared state for the fixture recorder. Public API calls made by the spec
+// files are recorded here as conformance cases and written to spec/fixtures/.
+
+export type FixtureCase = {
+  suite: string;
+  fn: string;
+  params: unknown;
+  expected?: string;
+  error?: string;
+};
+
+export const recorded: FixtureCase[] = [];
+
+const seen = new Set<string>();
+let currentSuite = '';
+
+export const setSuite = (suite: string) => {
+  currentSuite = suite;
+};
+
+export const record = (entry: Omit<FixtureCase, 'suite'>) => {
+  // params are JSON round-tripped so the dedupe key and the emitted fixture
+  // are exactly what a replaying implementation will see.
+  const params = JSON.parse(JSON.stringify(entry.params));
+  const key = JSON.stringify([entry.fn, params, entry.expected ?? null, entry.error ?? null]);
+  if (seen.has(key)) {
+    return;
+  }
+  seen.add(key);
+  recorded.push({ suite: currentSuite, ...entry, params });
+};
